# ============================================================
# 環境変数の雛形。これをコピーして「.env」を作り、実際の値を入れる。
#   コピー方法(PowerShell): Copy-Item .env.example .env
# .env は .gitignore で除外されるのでGitHubには上がりません（秘密情報なので絶対に公開しない）。
# ------------------------------------------------------------
# Tursoの接続情報（未設定ならローカルファイル file:calendar.db を使う）
TURSO_DATABASE_URL=libsql://your-db-name-xxxx.turso.io
TURSO_AUTH_TOKEN=ここにTursoで発行したトークンを貼る

# ---- LINE (LIFF) ログイン用 ※ここに自分の値を記入 ----
# LIFF ID: LINE Developers の LIFF タブで発行（例: 1234567890-abcdEFGH）
LIFF_ID=ここにLIFF IDを記入
# LINEログインチャネルの「チャネルID」(IDトークン検証に使用。数字)
LINE_CHANNEL_ID=ここにチャネルIDを記入

# セッション暗号化キー（任意の長いランダム文字列。ローカルでは未設定でも動く）
# SESSION_SECRET=任意のランダムな長い文字列
